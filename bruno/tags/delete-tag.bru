meta {
  name: Delete Tag
  type: http
  seq: 4
}

delete {
  url: {{baseUrl}}/tags/{{tagId}}
  body: none
  auth: none
}

headers {
  Accept: application/json
}

docs {
  Elimina una etiqueta por su ID.

  ## Respuesta
  Devuelve 200 con mensaje de confirmación.
  Devuelve 404 si la etiqueta no existe.
}
